    "siblings_only": true
  },
  "MD025": true,
  "MD026": {
    "punctuation": ".,;:!"
  },
  "MD029": {
    "style": "ordered"
  },
  "MD031": true,
  "MD032": true,
  "MD033": {
    "allowed_elements": ["details", "summary", "br"]
  },
  "MD034": true,
  "MD040": true,
  "MD041": true,
  "no-hard-tabs": true,
  "whitespace": true
}
